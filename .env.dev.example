# Copy to .env.dev and fill in your credentials.
# cycle.sh sources this with `set -a` so every key here is exported.

# Required — Wyze credentials
WYZE_EMAIL=you@example.com
WYZE_PASSWORD=your-password
WYZE_API_ID=your-api-id
WYZE_API_KEY=your-api-key

# Optional — TOTP secret for MFA-enabled accounts (base32 string from
# the Wyze app's "Use an authenticator app" enrollment screen)
# WYZE_TOTP_KEY=YOURBASE32SECRET

# Required for WebRTC playback in a browser — your dev machine's LAN
# IP that other devices on the network can reach. Without this, WebRTC
# advertises 127.0.0.1 as its ICE candidate and only loopback clients
# can play.
# BRIDGE_IP=192.168.1.50

# Local dev paths — cycle.sh sets these to ./local/* by default;
# uncomment and override only if you want to point elsewhere.
# STATE_DIR=./local/config
# SNAPSHOT_PATH=./local/snapshots/{cam_name}/%Y-%m-%d
# RECORD_PATH=./local/recordings/{cam_name}/%Y/%m/%d

# Optional knobs
# LOG_LEVEL=debug                 # trace | debug | info | warn | error
# FORCE_IOTC_DETAIL=true          # verbose TUTK / go2rtc logging
# MQTT_HOST=localhost             # presence enables MQTT publishing
# RECORD_ALL=true                 # auto-record every camera
# WEBHOOK_URLS=https://hook.example/wyze  # comma-separated state-change webhooks
