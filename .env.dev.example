# Copy to .env.dev and fill in your credentials
# Then: source .env.dev && go run ./cmd/wyze-bridge

# Required — Wyze credentials
WYZE_EMAIL=you@example.com
WYZE_PASSWORD=your-password
WYZE_API_ID=your-api-id
WYZE_API_KEY=your-api-key

# Required for WebRTC — your machine's LAN IP
# WB_IP=192.168.1.50

# Local dev paths (override Docker defaults)
STATE_DIR=./local/config
IMG_DIR=./local/img

# Optional
# LOG_LEVEL=debug
# FORCE_IOTC_DETAIL=true
# MQTT_HOST=localhost
# TOTP_KEY=your-totp-secret
